<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Access Denied - Bayzat</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #fafafa; }
    .container { width: 100%; max-width: 460px; padding: 2rem; text-align: center; }
    .logo { font-size: 1.5rem; font-weight: 900; letter-spacing: 0.2em; color: #7c3aed; }
    .icon { margin: 2.5rem 0 1.5rem; }
    .icon svg { width: 64px; height: 64px; color: #dc2626; }
    h1 { font-size: 1.75rem; font-weight: 600; color: #1f2937; }
    .message { margin-top: 0.75rem; color: #6b7280; line-height: 1.6; }
    .actions { margin-top: 2rem; display: flex; flex-direction: column; gap: 0.75rem; }
    .btn { display: flex; align-items: center; justify-content: center; gap: 0.5rem; width: 100%; padding: 0.875rem 1.5rem; border-radius: 0.5rem; font-size: 1rem; cursor: pointer; transition: all 0.15s; text-decoration: none; }
    .btn-primary { background: #7c3aed; color: white; border: none; }
    .btn-primary:hover { background: #6d28d9; }
    .btn-secondary { background: white; color: #1f2937; border: 1px solid #e5e7eb; }
    .btn-secondary:hover { background: #f9fafb; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
  </style>
</head>
<body>
  <div class="container">
    <div class="logo">BAYZAT</div>

    <div class="icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
      </svg>
    </div>

    <h1>Access Denied</h1>
    <p class="message">You don't have access to this content.</p>

    <div class="actions">
      <button class="btn btn-primary" onclick="handleSwitchAccount()">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        Try with a different account
      </button>
      <button class="btn btn-secondary" onclick="handleLogout()">Logout</button>
    </div>
  </div>

  <script>
    function getRedirectParam() {
      const params = new URLSearchParams(window.location.search);
      return params.get("redirect");
    }

    async function handleSwitchAccount() {
      await fetch("/api/logout", { method: "POST" });
      const redirect = getRedirectParam();
      const loginUrl = redirect ? "/?redirect=" + encodeURIComponent(redirect) : "/";
      window.location.href = loginUrl;
    }

    async function handleLogout() {
      await fetch("/api/logout", { method: "POST" });
      window.location.href = "/";
    }
  </script>
</body>
</html>

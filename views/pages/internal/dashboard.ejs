<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bayzat - Dashboard</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f9fafb; }
    header { background: white; border-bottom: 1px solid #e5e7eb; }
    .header-top { display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 2rem; }
    .logo { font-size: 1.5rem; font-weight: 900; letter-spacing: 0.2em; color: #7c3aed; }
    .header-right { display: flex; align-items: center; gap: 1rem; }
    .user-email { font-size: 0.875rem; color: #6b7280; }
    .logout-btn { padding: 0.5rem 1rem; border: 1px solid #7c3aed; border-radius: 0.375rem; background: transparent; color: #7c3aed; font-size: 0.875rem; cursor: pointer; transition: all 0.15s; }
    .logout-btn:hover { background: #7c3aed; color: white; }
    .login-btn { padding: 0.5rem 1rem; border: none; border-radius: 0.375rem; background: #7c3aed; color: white; font-size: 0.875rem; cursor: pointer; transition: all 0.15s; text-decoration: none; }
    .login-btn:hover { background: #6d28d9; }
    .tabs { display: flex; padding: 0 2rem; gap: 0; }
    .tab { padding: 0.75rem 1.25rem; font-size: 0.875rem; font-weight: 500; color: #6b7280; cursor: pointer; border: none; background: none; border-bottom: 2px solid transparent; transition: all 0.15s; }
    .tab:hover { color: #1f2937; }
    .tab.active { color: #7c3aed; border-bottom-color: #7c3aed; }
    main { max-width: 960px; margin: 0 auto; padding: 2.5rem 2rem; }
    h1 { font-size: 1.875rem; font-weight: 600; margin-bottom: 0.5rem; }
    .subtitle { color: #6b7280; margin-bottom: 2rem; }
    .card { background: white; border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 1.75rem; margin-bottom: 1rem; }
    .card h2 { font-size: 1.125rem; font-weight: 600; color: #1f2937; margin-bottom: 0.5rem; }
    .card p { color: #4b5563; line-height: 1.6; }
    .card-link { display: inline-block; margin-top: 0.75rem; color: #7c3aed; font-weight: 500; text-decoration: none; }
    .card-link:hover { text-decoration: underline; }
    .hidden { display: none; }
    .grant-form { display: flex; flex-direction: column; gap: 0.75rem; }
    .form-row { display: flex; gap: 0.75rem; }
    .form-row[hidden] { display: none; }
    .form-row input, .form-row select { flex: 1; padding: 0.625rem 0.875rem; border: 1px solid #e5e7eb; border-radius: 0.375rem; font-size: 0.875rem; background: white; }
    .form-row input:focus, .form-row select:focus { outline: none; border-color: #7c3aed; box-shadow: 0 0 0 2px rgba(124, 58, 237, 0.1); }
    .btn-grant { align-self: flex-start; padding: 0.625rem 1.25rem; border: none; border-radius: 0.375rem; background: #7c3aed; color: white; font-size: 0.875rem; font-weight: 500; cursor: pointer; white-space: nowrap; }
    .btn-grant:hover { background: #6d28d9; }
    .btn-grant:disabled { opacity: 0.5; cursor: not-allowed; }
    .access-list { margin-top: 1.25rem; }
    .access-item { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid #f3f4f6; }
    .access-item:last-child { border-bottom: none; }
    .access-slug { font-weight: 600; color: #1f2937; font-size: 0.875rem; }
    .access-email { color: #6b7280; font-size: 0.875rem; }
    .btn-revoke { padding: 0.375rem 0.75rem; border: 1px solid #ef4444; border-radius: 0.375rem; background: transparent; color: #ef4444; font-size: 0.75rem; cursor: pointer; }
    .btn-revoke:hover { background: #ef4444; color: white; }
    .access-badge { display: inline-block; margin-left: 0.5rem; padding: 0.125rem 0.5rem; border-radius: 1rem; font-size: 0.75rem; font-weight: 500; }
    .access-badge.internal { background: #ede9fe; color: #7c3aed; }
    .empty-state { text-align: center; padding: 2rem; color: #9ca3af; }
    .toast { position: fixed; bottom: 1.5rem; right: 1.5rem; padding: 0.75rem 1.25rem; border-radius: 0.5rem; font-size: 0.875rem; color: white; opacity: 0; transition: opacity 0.3s; pointer-events: none; }
    .toast.success { background: #059669; }
    .toast.error { background: #dc2626; }
    .toast.show { opacity: 1; }
  </style>
</head>
<body>
  <header>
    <div class="header-top">
      <div class="logo">BAYZAT</div>
      <div class="header-right">
        <% if (user.authenticated) { %>
          <span class="user-email"><%= user.email %></span>
          <button class="logout-btn" onclick="handleLogout()">Log out</button>
        <% } else { %>
          <a class="login-btn" href="/?redirect=/dashboard">Log in</a>
        <% } %>
      </div>
    </div>
    <% if (user.isAdmin) { %>
      <nav class="tabs">
        <button class="tab active" data-tab="pages" onclick="switchTab('pages')">Pages</button>
        <button class="tab" data-tab="admin" onclick="switchTab('admin')">Manage Access</button>
      </nav>
    <% } %>
  </header>

  <!-- Pages Tab -->
  <main id="tab-pages">
    <h1>Dashboard</h1>
    <p class="subtitle">Browse available content</p>

    <% if (user.isEmployee) { %>
      <div class="card">
        <h2>Internal Pages</h2>
        <p>Restricted to @bayzat.com accounts.</p>
        <a class="card-link" href="/internal-page">Sample Internal Page</a>
      </div>

      <div class="card">
        <h2>Private Pages</h2>
        <p>Per-user access — only allowed users can view.</p>
        <a class="card-link" href="/client">Client Page</a>
      </div>
    <% } %>
  </main>

  <% if (user.isAdmin) { %>
    <!-- Admin Tab -->
    <main id="tab-admin" class="hidden">
      <h1>Manage Access</h1>
      <p class="subtitle">Grant or revoke access to private pages</p>

      <div class="card">
        <h2>Grant Access</h2>
        <form id="grantForm" class="grant-form" onsubmit="grantAccess(event)">
          <div class="form-row">
            <input type="text" id="slugInput" placeholder="Page slug (e.g. applicant-tracking-system)" required />
            <select id="accessType" aria-label="Access type" required>
              <option value="">Select access type</option>
              <option value="client">Client (specific email)</option>
              <option value="internal">Internal (company only)</option>
            </select>
          </div>
          <div class="form-row" id="emailRow" hidden>
            <input type="email" id="emailInput" placeholder="Client email address" />
          </div>
          <button type="submit" class="btn-grant" id="grantBtn">Grant</button>
        </form>
      </div>

      <div class="card">
        <h2>Current Access</h2>
        <div id="accessList" class="access-list">
          <% if (accessEntries.length === 0) { %>
            <div class="empty-state">No access entries yet</div>
          <% } else { %>
            <% for (const entry of accessEntries) { %>
              <% if (entry.internal) { %>
                <div class="access-item">
                  <div>
                    <span class="access-slug">/<%= entry.slug %></span>
                    <span class="access-badge internal">Internal</span>
                  </div>
                  <button class="btn-revoke" onclick="revokeAccess('<%= entry.slug %>', null, this)">Revoke</button>
                </div>
              <% } %>
              <% for (const email of entry.allowedEmails) { %>
                <div class="access-item">
                  <div>
                    <span class="access-slug">/<%= entry.slug %></span>
                    <span class="access-email"> — <%= email %></span>
                  </div>
                  <button class="btn-revoke" onclick="revokeAccess('<%= entry.slug %>', '<%= email %>', this)">Revoke</button>
                </div>
              <% } %>
            <% } %>
          <% } %>
        </div>
      </div>
    </main>
  <% } %>

  <div class="toast" id="toast"></div>

  <script>
    <% if (user.isAdmin) { %>
    function switchTab(tab) {
      document.querySelectorAll(".tab").forEach(t => t.classList.remove("active"));
      document.querySelector(`[data-tab="${tab}"]`).classList.add("active");
      document.getElementById("tab-pages").classList.toggle("hidden", tab !== "pages");
      document.getElementById("tab-admin").classList.toggle("hidden", tab !== "admin");
      sessionStorage.setItem("activeTab", tab);
    }

    (function restoreTab() {
      const saved = sessionStorage.getItem("activeTab");
      if (saved && saved !== "pages") {
        sessionStorage.removeItem("activeTab");
        switchTab(saved);
      }
    })();

    document.getElementById("accessType").addEventListener("change", function () {
      const emailRow = document.getElementById("emailRow");
      const emailInput = document.getElementById("emailInput");
      const isClient = this.value === "client";
      emailRow.hidden = !isClient;
      emailInput.required = isClient;
      if (!isClient) emailInput.value = "";
    });

    async function grantAccess(e) {
      e.preventDefault();
      const slug = document.getElementById("slugInput").value.trim();
      const accessType = document.getElementById("accessType").value;
      const email = document.getElementById("emailInput").value.trim();

      if (!slug || !accessType) return;
      if (accessType === "client" && !email) return;

      const btn = document.getElementById("grantBtn");
      btn.disabled = true;
      btn.textContent = "Granting…";

      try {
        const res = await fetch("/api/admin/page-access", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ slug, email: email || null, accessType, action: "grant" }),
        });

        if (res.ok) {
          showToast("Access granted", "success");
          sessionStorage.setItem("activeTab", "admin");
          setTimeout(() => window.location.reload(), 500);
        } else {
          const data = await res.json();
          showToast(data.error || "Failed", "error");
          btn.disabled = false;
          btn.textContent = "Grant";
        }
      } catch {
        showToast("Request failed", "error");
        btn.disabled = false;
        btn.textContent = "Grant";
      }
    }

    async function revokeAccess(slug, email, btn) {
      const originalText = btn.textContent;
      btn.disabled = true;
      btn.textContent = "Revoking…";

      try {
        const res = await fetch("/api/admin/page-access", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ slug, email, action: "revoke" }),
        });

        if (res.ok) {
          showToast("Access revoked", "success");
          sessionStorage.setItem("activeTab", "admin");
          setTimeout(() => window.location.reload(), 500);
        } else {
          showToast("Failed to revoke", "error");
          btn.disabled = false;
          btn.textContent = originalText;
        }
      } catch {
        showToast("Request failed", "error");
        btn.disabled = false;
        btn.textContent = originalText;
      }
    }
    <% } %>

    function showToast(msg, type) {
      const toast = document.getElementById("toast");
      toast.textContent = msg;
      toast.className = `toast ${type} show`;
      setTimeout(() => toast.classList.remove("show"), 2500);
    }

    async function handleLogout() {
      await fetch("/api/logout", { method: "POST" });
      window.location.href = "/";
    }
  </script>
</body>
</html>
